rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // Guides carry custom claims { role: 'guide', orgId } set at registration.
    function isGuideOfOrg(orgId) {
      return isSignedIn()
        && request.auth.token.role == 'guide'
        && request.auth.token.orgId == orgId;
    }

    function isAnyGuide() {
      return isSignedIn() && request.auth.token.role == 'guide';
    }

    // Kids have no claims; membership comes from their server-written profile.
    function isCampMember(campId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.campId == campId;
    }

    function campOrg(campId) {
      return get(/databases/$(database)/documents/camps/$(campId)).data.orgId;
    }

    match /config/{document=**} { allow read, write: if false; }

    // Server-only bookkeeping for Cloud Functions' Firestore-backed rate
    // limiter (registerGuide, claimCampCode). Never client-readable/writable —
    // the Admin SDK bypasses rules entirely, so this block exists purely to
    // make the deny explicit (defense-in-depth alongside the final catch-all).
    match /rateLimits/{document=**} { allow read, write: if false; }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if false;
      // Only a guide may change their own profile, and only the campId field
      // (switching which camp they're viewing). Kids never write their profile:
      // their campId is set server-side by claimCampCode and is immutable on the
      // client — otherwise an anonymous kid could point campId at any camp and
      // read it (isCampMember keys off this field). The target camp must belong
      // to the guide's own org, so a guide cannot camp-hop across organisations
      // either.
      allow update: if isSignedIn() && request.auth.uid == userId
        && request.auth.token.role == 'guide'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['campId'])
        && get(/databases/$(database)/documents/camps/$(request.resource.data.campId))
             .data.orgId == request.auth.token.orgId;
    }

    match /organizations/{orgId} {
      // Guides of the org can read it (name, invite code for owners' UI).
      allow read: if isGuideOfOrg(orgId);
      // Create/delete and all other fields are server-only (registerGuide).
      allow create, delete: if false;
      // The one exception: the owner may set THIS org's camp-code prefix and/or
      // camp logo URL — and only those fields. Everything else stays
      // server-only. Each field is validated only when it's actually changing.
      allow update: if isGuideOfOrg(orgId)
        && request.auth.uid == resource.data.ownerUid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['codePrefix', 'logoUrl'])
        && (!('codePrefix' in request.resource.data.diff(resource.data)
                .affectedKeys())
            || (request.resource.data.codePrefix is string
                && request.resource.data.codePrefix.size() >= 2
                && request.resource.data.codePrefix.size() <= 8
                && request.resource.data.codePrefix.matches('[A-Z0-9]+')))
        && (!('logoUrl' in request.resource.data.diff(resource.data)
                .affectedKeys())
            || request.resource.data.logoUrl is string);

      match /members/{uid} {
        allow read: if isGuideOfOrg(orgId);
        allow write: if false;
      }

      match /locations/{document=**} {
        // Kids need map locations too; their org is on their profile.
        allow read: if isGuideOfOrg(orgId)
          || (isSignedIn()
              && exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid))
                   .data.orgId == orgId);
        allow write: if isGuideOfOrg(orgId);
      }

      // Announcement templates: prewritten messages guides manage and send.
      // Guide-only (kids never see them; announcements are pushed separately).
      match /announcementTemplates/{templateId} {
        allow read, write: if isGuideOfOrg(orgId);
      }
    }

    match /camps/{campId} {
      allow read: if isCampMember(campId)
        || (isSignedIn() && isGuideOfOrg(resource.data.orgId));
      allow create: if isGuideOfOrg(request.resource.data.orgId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isGuideOfOrg(resource.data.orgId);
      // Deletion is server-only (the deleteCamp callable), which cascades to
      // subcollections, top-level codes, and Storage photos. A direct client
      // delete of just the camp doc would orphan all of those forever.
      allow delete: if false;

      match /{sub}/{doc=**} {
        allow read: if isCampMember(campId) || isGuideOfOrg(campOrg(campId));
        allow write: if isGuideOfOrg(campOrg(campId));
      }
    }

    // Top-level codes: org guides manage their own org's codes; kids never
    // read them (claim goes through the claimCampCode function).
    match /codes/{code} {
      // get: a guide may read a single code of their own org. resource is null
      // when the code doesn't exist (collision-check on generation) — allow that
      // so a non-existent read returns empty instead of erroring to a deny.
      allow get: if isAnyGuide()
        && (resource == null
            || request.auth.token.orgId == resource.data.orgId);
      // list: only queries constrained to the guide's own org (the client always
      // filters `where orgId == <claim>`); Firestore denies any query it can't
      // prove satisfies this.
      allow list, delete: if isAnyGuide()
        && request.auth.token.orgId == resource.data.orgId;
      // create: a guide may only mint a code for their own org AND only pointing
      // at a camp that belongs to that same org (campOrg get). This stops a guide
      // forging a code whose campId targets another org's camp.
      allow create: if isAnyGuide()
        && request.auth.token.orgId == request.resource.data.orgId
        && campOrg(request.resource.data.campId) == request.auth.token.orgId;
      // update is server-only: claiming (used/usedBy) and releasing codes both
      // run through Cloud Functions on the Admin SDK, which bypasses rules. No
      // client path updates a code, so allowing it only invited tampering
      // (flipping `used`, rewriting campId/orgId).
      allow update: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
