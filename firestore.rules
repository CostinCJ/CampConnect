rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Config is readable by anyone (needed for invite code validation before auth)
    match /config/{document=**} {
      allow read: if true;
      allow write: if false;  // only via Firebase Console
    }

    // Users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Master locations — publicly readable, authenticated writes
    match /locations/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Camps and all subcollections
    match /camps/{campId} {
      allow read: if true;
      allow write: if request.auth != null;

      // All subcollections: codes, teams, pointsHistory, announcements,
      // emergencyAlerts, sessionLocations
      match /{subcollection}/{document=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
