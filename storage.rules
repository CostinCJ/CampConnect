rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    // Guide-of-org check via custom claims (set server-side at registration),
    // mirroring firestore.rules' isGuideOfOrg.
    function isGuideOfOrg(orgId) {
      return isSignedIn()
        && request.auth.token.role == 'guide'
        && request.auth.token.orgId == orgId;
    }

    // The owning org of a camp, read cross-service from Firestore.
    function campOrg(campId) {
      return firestore.get(/databases/(default)/documents/camps/$(campId)).data.orgId;
    }

    // True if the signed-in user's stored campId matches this camp (mirrors
    // firestore.rules' isCampMember, via cross-service firestore.get()).
    function isCampMember(campId) {
      return hasProfile() && userData().campId == campId;
    }

    // Master location photos — org-scoped. Only users belonging to the org may
    // read (a guide of the org, or a kid whose profile orgId matches — kids need
    // them for the map); only a guide of this org may write.
    match /organizations/{orgId}/locations/{locationId}/photo.jpg {
      allow read: if isGuideOfOrg(orgId)
        || (hasProfile() && userData().orgId == orgId);
      allow write: if isGuideOfOrg(orgId);
    }

    // Session location group photos (may contain images of children).
    // Camp-scoped: readable by a guide of the camp's org, or by a signed-in
    // member (kid) whose profile campId matches this camp. Writable only by a
    // guide of the camp's org — not by guides of other organisations.
    match /camps/{campId}/sessionLocations/{sessionLocId}/group_photo.jpg {
      allow read: if isGuideOfOrg(campOrg(campId)) || isCampMember(campId);
      allow write: if isGuideOfOrg(campOrg(campId));
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
