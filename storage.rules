rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    // Guide-of-org check via custom claims (set server-side at registration),
    // mirroring firestore.rules' isGuideOfOrg.
    function isGuideOfOrg(orgId) {
      return isSignedIn()
        && request.auth.token.role == 'guide'
        && request.auth.token.orgId == orgId;
    }

    // The owning org of a camp, read cross-service from Firestore.
    function campOrg(campId) {
      return firestore.get(/databases/(default)/documents/camps/$(campId)).data.orgId;
    }

    // True if the signed-in user's stored campId matches this camp (mirrors
    // firestore.rules' isCampMember, via cross-service firestore.get()).
    function isCampMember(campId) {
      return hasProfile() && userData().campId == campId;
    }

    // Camp logo — org branding shown on the journal PDF export. Readable by any
    // org member (kids export their own journal with the camp's logo); writable
    // by a guide of the org.
    match /organizations/{orgId}/logo.jpg {
      allow read: if isGuideOfOrg(orgId)
        || (hasProfile() && userData().orgId == orgId);
      allow create, update: if isGuideOfOrg(orgId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isGuideOfOrg(orgId);
    }

    // Master location photos — org-scoped. Only users belonging to the org may
    // read (a guide of the org, or a kid whose profile orgId matches — kids need
    // them for the map); only a guide of this org may write.
    match /organizations/{orgId}/locations/{locationId}/photo.jpg {
      allow read: if isGuideOfOrg(orgId)
        || (hasProfile() && userData().orgId == orgId);
      // create/update and delete are split: on a delete request.resource is
      // null, so a combined `allow write` with size/content-type conditions
      // would deny every client-side delete (orphaning replaced photos).
      allow create, update: if isGuideOfOrg(orgId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isGuideOfOrg(orgId);
    }

    // Session location group photos (may contain images of children).
    // Org-scoped so the rule authorises via the guide's orgId claim directly —
    // the same proven pattern as master-location photos — instead of a
    // cross-service Firestore lookup. Readable by a guide of the org or by a
    // member (kid) whose profile orgId matches; writable only by an org guide.
    match /organizations/{orgId}/sessionPhotos/{campId}/{sessionLocId}/group_photo.jpg {
      allow read: if isGuideOfOrg(orgId)
        || (hasProfile() && userData().orgId == orgId);
      allow create, update: if isGuideOfOrg(orgId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isGuideOfOrg(orgId);
    }

    // Legacy camp-scoped session photos (pre org-scoped path). Kept read-only-ish
    // so photos uploaded before the move still display; new uploads use the
    // org-scoped path above.
    match /camps/{campId}/sessionLocations/{sessionLocId}/group_photo.jpg {
      allow read: if isGuideOfOrg(campOrg(campId)) || isCampMember(campId);
      allow delete: if isGuideOfOrg(campOrg(campId));
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
