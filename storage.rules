rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Master location photos — any authenticated user can read; only authenticated can write
    match /locations/{locationId}/photo.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Session location group photos
    match /camps/{campId}/sessionLocations/{sessionLocId}/group_photo.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
